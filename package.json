    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:node": "node --test scripts/*.test.mjs",
    "test:ci": "jest --ci --coverage --forceExit && pnpm test:node",
    "test:rls": "node supabase/tests/run-rls-tests.mjs",
    "lint:migrations": "node supabase/tests/lint-migrations.mjs",
    "lint:edge-functions": "for dir in supabase/functions/*/; do func=$(basename \"$dir\"); echo \"Checking: $func\" && deno check \"$dir/index.ts\"; done",
