{
  "servers": {
    "TestSprite": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@testsprite/testsprite-mcp@latest"
      ],
      "env": {
        "API_KEY": "${input:testsprite-api-key}"
      }
    }
  },
  "inputs": [
    {
      "id": "testsprite-api-key",
      "type": "promptString",
      "description": "TestSprite API key",
      "password": true
    }
  ]
}
